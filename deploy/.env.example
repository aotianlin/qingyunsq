# CampusForum production deployment variables
# Copy this file to .env, then replace every ChangeMe value before running install.sh.

# Site
APP_DOMAIN=localhost
TENANT_MODE=standalone

# MySQL
MYSQL_ROOT_PASSWORD=ChangeMe-strong-root-pwd
MYSQL_DATABASE=campus_forum
MYSQL_USER=campusforum
MYSQL_PASSWORD=ChangeMe-strong-app-pwd
SPRING_DATASOURCE_URL=jdbc:mysql://mysql:3306/campus_forum?useUnicode=true&characterEncoding=UTF-8&serverTimezone=Asia/Shanghai

# Redis. Sa-Token currently uses Redis-backed tik tokens, not JWT.
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=ChangeMe-strong-redis-pwd

# Required security secrets. Generate with: openssl rand -base64 48
SIGNED_URL_SECRET=ChangeMe-generate-48-byte-random-base64
CRYPTO_MASTER_KEY=ChangeMe-generate-48-byte-random-base64
CORS_ALLOWED_ORIGINS=https://your-campus.edu
WS_ALLOWED_ORIGINS=https://your-campus.edu
WS_TICKET_ENFORCED=false
WS_TICKET_TTL_SECONDS=30
SPRINGDOC_ENABLED=false

# AI. Tenant admin AI config stored in tenants.ai_config has priority.
AI_PROVIDER=mock
AI_API_KEY=
AI_BASE_URL=https://api.deepseek.com
AI_MODEL=deepseek-v4-flash
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_API_KEY=
MIMO_BASE_URL=https://api.xiaomimimo.com/v1
MIMO_API_KEY=

# WeChat mini program login
WECHAT_MINI_PROGRAM_APP_ID=
WECHAT_MINI_PROGRAM_APP_SECRET=

# Storage. Source supports: oss | local. Production default is Alibaba Cloud OSS.
STORAGE_TYPE=oss
STORAGE_OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
STORAGE_OSS_HOST=your-bucket.oss-cn-hangzhou.aliyuncs.com
OSS_ACCESS_KEY=ChangeMe-oss-access-key
OSS_SECRET_KEY=ChangeMe-oss-secret-key
OSS_BUCKET=campusforum
# Only used when STORAGE_TYPE=local. Local mode is suitable for dev/single-node smoke tests.
STORAGE_LOCAL_PATH=/app/uploads
ALLOWED_ASSET_HOSTS=cdn.your-campus.edu,storage.your-campus.edu

# Search
SEARCH_MEILISEARCH_HOST=http://meilisearch:7700
MEILI_MASTER_KEY=ChangeMe-strong-meili-key

# SMTP mail
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_STARTTLS_ENABLE=true
SMTP_SSL_ENABLE=false
SMTP_PROXY_HOST=
SMTP_PROXY_PORT=
SMTP_PROXY_USERNAME=
SMTP_PROXY_PASSWORD=
SMTP_SOCKS_HOST=
SMTP_SOCKS_PORT=
SMTP_SSL_PROTOCOLS=
SMTP_SSL_TRUST=
SMTP_SSL_CHECK_SERVER_IDENTITY=
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_MOCK_ENABLED=false
EMAIL_FROM=noreply@your-campus.edu
RESET_LINK_BASE=https://your-campus.edu/reset-password

# File preview and upload hardening
OFFICE_PREVIEW_URL=http://kkfileview:8012/onlinePreview
UPLOAD_REAL_MIME_CHECK=true
