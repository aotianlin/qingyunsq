# ===== CampusForum 部署配置 =====
# ⚠️  生产部署前必读：deploy/SECURITY.md
# 自 commit 39875dc 起，application-prod.yml 已移除以下变量的弱默认值，
# 任何一项未设置都会导致后端启动失败（占位符无法解析）。
#
# ===========================================================================
# 🔥 2026-05-22 安全加固（security-hardening spec）必读 🔥
# ===========================================================================
# 本次加固新增以下"必填"环境变量（已在 application-prod.yml 中无默认值）：
#   - CRYPTO_MASTER_KEY        AES-GCM 主密钥，≥ 32 字节随机串，缺失后端启动失败
#   - CORS_ALLOWED_ORIGINS     CORS 跨域来源白名单，逗号分隔
#
# 部署顺序（必须严格按此顺序）：
#   1) 应用数据库迁移：见 db/migrations/README.md
#        - V20260522_01__reset_token_hash.sql  （reset_token 改 SHA-256 哈希）
#        - V20260522_02__resource_sha256.sql   （resources 新增 file_sha256 列）
#   2) 配置本文件中所有 ChangeMe* 变量与新增的安全变量
#   3) 启动新版本后端（缺失任意必填变量会启动失败）
#   4) 一周内观察日志，无异常后将 WS_TICKET_ENFORCED 切到 true
#
# 详细说明：deploy/SECURITY.md
# ===========================================================================

# 站点域名
APP_DOMAIN=localhost

# 租户模式: standalone (独立部署) | multi (多租户 SaaS)
TENANT_MODE=standalone

# ===== MySQL =====
MYSQL_ROOT_PASSWORD=ChangeMe-strong-root-pwd
MYSQL_DATABASE=campus_forum
# 应用账号（请使用最小权限账号，不要用 root）
MYSQL_USER=campusforum
MYSQL_PASSWORD=ChangeMe-strong-app-pwd
# 完整 JDBC URL；若使用内置 docker-compose，主机为 mysql
SPRING_DATASOURCE_URL=jdbc:mysql://mysql:3306/campus_forum?useUnicode=true&characterEncoding=UTF-8&serverTimezone=Asia/Shanghai

# ===== Redis =====
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=ChangeMe-strong-redis-pwd

# ===== Sa-Token / 签名 URL =====
# 注意：Sa-Token 当前为 Redis 持久化 + tik 风格 token（非 JWT 模式），
# 因此**不存在**生效的 JWT_SECRET / SA_TOKEN_JWT_SECRET_KEY 配置项。
# 用于守护 token → loginId 映射的实际是 REDIS_PASSWORD（见上方 Redis 段）。
# 详见 deploy/SECURITY.md §1.1。
#
# 下面这一行仅作为"保留位"存在，便于沿用旧 .env 脚本的运维不报错——
# Sa-Token 在未引入 sa-token-jwt 依赖前不会读取它，设置任何值都不会生效。
# 若未来 Sa-Token 切换到 JWT 模式（引入 sa-token-jwt 依赖 + 配置 sa-token.jwt-secret-key），
# 需先制定密钥轮转计划（新旧密钥灰度切换 + 强制全员重新登录）。
# JWT_SECRET=（保留位，未启用；若未来 Sa-Token 切换到 JWT 模式，需先做密钥轮转计划）

# 资源下载/预览短期签名的 HMAC 密钥，建议 64+ 位随机串
# 用 openssl rand -base64 48 生成（≥ 32 字节随机串）
# 缺失或仍含 ChangeMe / please-override / dev-only-change-me 等弱 token 时，
# SecurityStartupValidator 在 prod profile 下会直接抛错阻止启动（漏洞 3）。
SIGNED_URL_SECRET=ChangeMe-please-generate-64-bytes-of-random-base64

# ===== 对称加密主密钥（缺陷 1.1 加固，必填）=====
# 用于加密 tenants.ai_config 中的 AI API Key 等敏感字段
# 必须 ≥ 32 字节随机串；用 openssl rand -base64 48 生成（≥ 32 字节随机串）
# 缺失或仍含 ChangeMe / please-override / dev-only-change-me 等弱 token 时，
# SecurityStartupValidator 在 prod profile 下会直接抛错阻止启动（漏洞 1）。
CRYPTO_MASTER_KEY=ChangeMe-please-generate-32+-bytes-of-random-string-here

# ===== CORS 跨域来源（缺陷 1.30 加固，必填）=====
# 逗号分隔的允许跨域域名；生产强制配置为前端域名，禁止保留 localhost
CORS_ALLOWED_ORIGINS=https://your-campus.edu

# ===== 头像 / 封面 URL 域名白名单（缺陷 1.20 加固，可选）=====
# 逗号分隔的允许域名列表；与 application.yml 中 security.upload.self-hosts
# （由 STORAGE_MINIO_ENDPOINT 自动推导）合并作为头像/封面 URL 白名单。
# 漏洞 15 修复后，空白名单语义反转为"仅允许本站存储域名"，所以即使留空也不再"全放行"。
ALLOWED_ASSET_HOSTS=cdn.your-campus.edu,storage.your-campus.edu

# ===== WebSocket 票据强制（缺陷 1.3 加固，可选）=====
# true 时拒绝旧 token query 路径，强制使用 ws-ticket；
# 建议先按默认 false 部署一周观察前端兼容情况，再切到 true。
WS_TICKET_ENFORCED=false

# ===== Knife4j / OpenAPI 文档开关（漏洞 2，T2.3）=====
# 生产必须保持 false（默认即 false）。仅运维需要在内网开启时才设为 true，
# 即便如此 nginx 边缘也对 swagger / api-docs / webjars 路径返回 404（双重屏蔽，T2.4）。
SPRINGDOC_ENABLED=false

# ===== AI 服务 =====
AI_PROVIDER=mock
AI_API_KEY=
AI_BASE_URL=https://api.deepseek.com/v1
AI_MODEL=deepseek-chat

# ===== MinIO 对象存储（S3 兼容） =====
# MinIO 对外地址，会被自动加入 application.yml 的 security.upload.self-hosts，
# 进而成为头像/封面 URL 白名单的一部分（漏洞 15）。
STORAGE_MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=ChangeMe-not-minioadmin
MINIO_SECRET_KEY=ChangeMe-not-minioadmin
MINIO_BUCKET=campusforum

# ===== MeiliSearch =====
SEARCH_MEILISEARCH_HOST=http://meilisearch:7700
MEILI_MASTER_KEY=ChangeMe-strong-meili-key

# ===== SMTP 邮件服务 =====
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_STARTTLS_ENABLE=true
SMTP_SSL_ENABLE=false
SMTP_PROXY_HOST=
SMTP_PROXY_PORT=
SMTP_PROXY_USERNAME=
SMTP_PROXY_PASSWORD=
SMTP_SOCKS_HOST=
SMTP_SOCKS_PORT=
SMTP_SSL_PROTOCOLS=
SMTP_SSL_TRUST=
SMTP_SSL_CHECK_SERVER_IDENTITY=
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM=noreply@your-campus.edu
RESET_LINK_BASE=https://your-campus.edu/reset-password

# ===== WebSocket 跨域来源（CSWSH 防御）=====
# 多个域名用逗号分隔；务必不要保留默认 localhost
WS_ALLOWED_ORIGINS=https://your-campus.edu

# ===== 文件预览（可选） =====
OFFICE_PREVIEW_URL=http://kkfileview:8012/onlinePreview
